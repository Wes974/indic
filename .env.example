# indic — clés d'enrichers (copie en .env ; sur le VPS : ~/indic/.env)
#
# Un enricher s'active AUTOMATIQUEMENT quand sa clé est présente ET la requête
# autorisée par le token. Laisse vide ce que tu n'as pas — aucun impact.
# Injecté dans le container via env_file (docker-compose).
#
# FORMAT env_file : pas de commentaire en fin de ligne, valeurs sans guillemets.
# Statut API GRATUITE vérifié en juillet 2026 :
#   ✅ free fiable   ⚠️ free à caveat (quota faible / approbation / conformité)
#   ❌ pas d'API free exploitable (payant / supprimé) — laisse vide sauf abonnement.
# BIND / REFRESH / DATA_DIR sont posés par docker-compose, pas ici.

# Accès — protège les enrichers à clé.  openssl rand -hex 24
INDIC_TOKEN=

# ═══ IP : scan / réputation / anonymat ════════════════════════════════════
# GreyNoise ✅ Community API gratuite (scanner vs benign) | https://viz.greynoise.io/account
GREYNOISE_API_KEY=
# AbuseIPDB ✅ free 1000 checks/jour | https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=
# BinaryEdge ❌ fermé 31/03/2025 (→ Coalition) — conservé pour compat | https://docs.binaryedge.io
BINARYEDGE_API_KEY=
# IPQualityScore ✅ free ~5000/mois (fraud/proxy/VPN) | https://www.ipqualityscore.com/user/settings
IPQUALITYSCORE_API_KEY=
# IPinfo ✅ free (geo/ASN ; privacy/VPN detection = payant) | https://ipinfo.io/account/token
IPINFO_TOKEN=
# ipdata.co ✅ free ~1500/jour | https://ipdata.co
IPDATA_API_KEY=
# proxycheck.io ✅ free 1000/jour | https://proxycheck.io/dashboard
PROXYCHECK_API_KEY=
# vpnapi.io ✅ free 1000/jour | https://vpnapi.io/dashboard
VPNAPI_KEY=
# LeakIX ✅ free (clé API, services exposés/fuites) | https://leakix.net/settings/api
LEAKIX_API_KEY=
# iknowwhatyoudownload — historique torrents par IP (Peer API api.antitor.com) — clé DÉMO gratuite par email (limitée) | https://iknowwhatyoudownload.com/en/api/
IKNOWWHATYOUDOWNLOAD_API_KEY=
# Censys Platform ✅ free 100 crédits/mois (lookup host/domaine/cert) — compte free suffit.
# CENSYS_API_KEY = Personal Access Token (Bearer). CENSYS_ORG_ID reste VIDE en free
# (l'org-id n'existe/ne sert que sur plan payant Starter+). | https://platform.censys.io
CENSYS_API_KEY=
CENSYS_ORG_ID=
# MaxMind GeoLite2 ✅ free (db geo, clé licence) | https://www.maxmind.com/en/accounts/current/license-key
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
# FullHunt ⚠️ free quota faible (attack surface) | https://fullhunt.io
FULLHUNT_API_KEY=
# Scamalytics ✅ free (compte perso = user + clé ; URL apiN.scamalytics.com/<user>/?key=…&ip=) | https://scamalytics.com/ip/api
SCAMALYTICS_API_USER=
SCAMALYTICS_API_KEY=
# Criminal IP ⚠️ free incertain (sources 2026 divergentes : API sur tous plans OU réservée payant) | https://www.criminalip.io
CRIMINALIP_API_KEY=
# Netlas ⚠️ free 50 req/jour, NON-commercial | https://app.netlas.io/profile
NETLAS_API_KEY=
# Shodan ⚠️ clé free mais 0 crédit → host/search bloqués ; membership $49 one-time requis | https://account.shodan.io
SHODAN_API_KEY=
# Moteurs CN — free avec vérif tél / quota crédits (à confirmer) :
# FOFA ⚠️ free (vérif téléphone, F-points limités) | https://fofa.info
FOFA_EMAIL=
FOFA_KEY=
# ZoomEye ⚠️ free (crédits mensuels) | https://www.zoomeye.org/profile
ZOOMEYE_API_KEY=
# Quake/360 ⚠️ free (inscription CN) | https://quake.360.net
QUAKE_API_KEY=
# ❌ Pas d'API free — laisser vide :
# Onyphe ❌ free API SUPPRIMÉE (payant €599+/mois) | https://www.onyphe.io/pricing
ONYPHE_API_KEY=
# Spur ❌ payant (proxy résidentiel) | https://spur.us
SPUR_API_KEY=

# ═══ Domaine / DNS / passive DNS / web ════════════════════════════════════
# urlscan.io ✅ free généreux : 5000 scans + 1000 search/jour | https://urlscan.io/user/profile
URLSCAN_API_KEY=
# urlscan.io Pro ✅ free (même clé que free, ou clé dédiée avec quotas plus élevés ; enrichissement verdicts)
URLSCAN_PRO_API_KEY=
# CertSpotter/sslmate ✅ free (CT search, ~100 host-req/h, perso/éval) | https://sslmate.com/account/api_credentials
CERTSPOTTER_API_KEY=
# HackerTarget ⚠️ free 50/jour (clé optionnelle) | https://hackertarget.com/ip-tools/
HACKERTARGET_API_KEY=
# Validin ⚠️ free Community très limité (~50 req/mois) | https://app.validin.com
VALIDIN_API_KEY=
# WhoisXML ⚠️ free ~500 crédits partagés (se vident vite) | https://whois.whoisxmlapi.com
WHOISXML_API_KEY=
# SecurityTrails ⚠️ free mourant (50 req/mois, signup pas toujours ouvert post-Recorded Future) | https://securitytrails.com
SECURITYTRAILS_API_KEY=
# ❌ « free » sans données exploitables / payant — laisser vide :
# BuiltWith ❌ free API = compteurs only (technos par domaine = payant) | https://api.builtwith.com
BUILTWITH_API_KEY=
# DNSlytics ❌ free = IP2ASN only (reverse/DNS/historique = crédits payants) | https://dnslytics.com
DNSLYTICS_API_KEY=
# DomainTools ❌ payant enterprise | https://www.domaintools.com
DOMAINTOOLS_API_USERNAME=
DOMAINTOOLS_API_KEY=

# ═══ Malware / fichiers / sandbox ═════════════════════════════════════════
# abuse.ch ✅ free — 1 clé pour MalwareBazaar/URLhaus/ThreatFox/YARAify (login SSO social requis) | https://auth.abuse.ch
ABUSE_CH_API_KEY=
# VirusTotal ✅ free 500/jour, 4/min (non-commercial) | https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=
# MetaDefender Cloud (OPSWAT) ✅ multi-AV hash + réputation IP/URL/domaine, 4000/jour = LA clé de ton compte OPSWAT | https://metadefender.opswat.com
METADEFENDER_API_KEY=
# MalShare ✅ free ~2000/jour | https://malshare.com/register.php
MALSHARE_API_KEY=
# Traceix + AURA ✅ free (PCEF, nonprofit) — MÊME clé pour les deux sources :
#   traceix = verdicts antivirus multi-moteurs + capacités CAPA/ATT&CK + règle YARA
#   aura    = classification IA (corpus distinct de Traceix ; PE/ELF uniquement)
# Recherche par SHA-256 UNIQUEMENT (MD5/SHA-1 non couverts) | https://traceix.com/
TRACEIX_API_KEY=
# Filescan.io/OPSWAT ✅ free Community | https://www.filescan.io/api
FILESCAN_API_KEY=
# Hybrid Analysis ⚠️ free (recherche OK ; submit/download = vetting manuel) | https://www.hybrid-analysis.com
HYBRIDANALYSIS_API_KEY=
# tria.ge ⚠️ free « researcher » sur approbation manuelle (Recorded Future) | https://tria.ge/account
TRIAGE_API_KEY=
# Kaspersky OpenTIP ⚠️ free mais conformité sanctions US (BIS 2024) à vérifier | https://opentip.kaspersky.com
KASPERSKY_OPENTIP_KEY=
# ❌ Free supprimé / mort — laisser vide :
# Intezer ❌ Community fermé (~2023, trial/payant only) | https://analyze.intezer.com
INTEZER_API_KEY=
# Any.Run ❌ API payante (Community = UI web sans API) | https://app.any.run
ANYRUN_API_KEY=

# ═══ Threat intel / IOC ═══════════════════════════════════════════════════
# AlienVault OTX ✅ free 10k req/h | https://otx.alienvault.com/api
OTX_API_KEY=
# Maltiverse ⚠️ free 100/jour (racheté Lumu, maintenu) | https://maltiverse.com
MALTIVERSE_API_KEY=
# Pulsedive ⚠️ free 50/jour, 500/mois | https://pulsedive.com/api
PULSEDIVE_API_KEY=
# Google Safe Browsing ⚠️ free mais v4 sunset 03/2027 → coder v5 | https://console.cloud.google.com
GOOGLE_SAFEBROWSING_API_KEY=
# Intelligence X ⚠️ free tier (crédits opaques, non-commercial) | https://intelx.io/account?tab=developer
INTELX_API_KEY=
# PhishTank ⚠️ pas de NOUVELLE clé (inscriptions fermées depuis 2020) ; feed anonyme dispo sans clé | https://phishtank.org
PHISHTANK_API_KEY=
# MISP self-hosted (optionnel)
MISP_URL=
MISP_API_KEY=
# OpenCTI (optionnel)
OPENCTI_URL=
OPENCTI_TOKEN=
# Push : vérification TLS active par défaut. Mettre à 1 UNIQUEMENT si ton MISP/OpenCTI
# interne présente un cert self-signed (ex. misp-core:443 sur le réseau docker). Jamais pour une URL publique.
INDIC_PUSH_INSECURE_TLS=

# ═══ Breaches / email / identité ══════════════════════════════════════════
# Hunter.io ✅ free ~25-50/mois (email finder/verify) | https://hunter.io/api-keys
HUNTER_IO_API_KEY=
# LeakCheck ⚠️ endpoint public free limité + tier payant | https://leakcheck.io/dashboard
LEAKCHECK_API_KEY=
# EmailRep ⚠️ durci (Sublime Security ; clé sur demande/payant) | https://emailrep.io/key
EMAILREP_API_KEY=
# ❌ Payant — laisser vide :
# Have I Been Pwned ❌ payant ~3.95$/mo | https://haveibeenpwned.com/API/Key
HIBP_API_KEY=
# DeHashed ❌ payant | https://dehashed.com/profile
DEHASHED_API_KEY=
DEHASHED_EMAIL=

# ═══ CVE / vulnérabilités ═════════════════════════════════════════════════
# NVD ✅ free (50 req/30s avec clé) | https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
# VulnCheck ✅ free Community 1000 req/min (KEV + miroir NVD) | https://vulncheck.com/token/newtoken
VULNCHECK_API_KEY=
# Vulners ⚠️ free 100 crédits/mois ; lookup CVE-par-ID gratuit illimité (déc. 2025) | https://vulners.com/userinfo
VULNERS_API_KEY=

# ═══ Crypto / divers ══════════════════════════════════════════════════════
# Etherscan ✅ free 100k/jour — API V2 obligatoire (base api.etherscan.io/v2/api + chainid) | https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
# GitHub ✅ free PAT 5000 req/h (ton compte) | https://github.com/settings/tokens
GITHUB_TOKEN=


# ═══ Sources désactivées ═══════════════════════════════════════════════════
# Noms d'enrichers à ne PAS appeler, séparés par des virgules (ex. fofa,zoomeye).
# Utile quand un quota est épuisé ou qu'une source est cassée : elle n'est plus
# appelée du tout — ni latence, ni appel gaspillé, ni ligne d'erreur dans la
# fiche — sans avoir à retirer sa clé, qui reste prête pour la réactivation.
INDIC_DISABLED_SOURCES=

# ═══ Historique (opt-in) ════════════════════════════════════════════════════
# Active l'historique SQLite des lookups (alimente dashboard, corrélations).
INDIC_HISTORY=
# Rétention en jours (défaut 90). Purge automatique tous les 100 inserts.
INDIC_HISTORY_RETENTION_DAYS=90
# ═══ Veille (proactif) — alertes Pushover ═════════════════════════════════
# Active la veille planifiée (Module B CISA KEV, etc.). INDIC_VEILLE_INTERVAL_HOURS défaut 6.
INDIC_VEILLE_ENABLED=
# Module pastes : mots-clés à surveiller dans les leaks/pastes (IntelX), séparés par des virgules.
INDIC_VEILLE_KEYWORDS=
# Modules veille sans clé : CISA KEV (nouvelles CVE exploitées) + advisories sécu Apple (macOS/iOS).
# URLs surchargeables (défauts intégrés) :
# INDIC_FEED_KEV=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
# INDIC_FEED_APPLE_SEC=https://support.apple.com/en-us/100100
# Pushover ✅ (app 10k msg/mois gratuits). TOKEN = app créée sur pushover.net/apps/build ;
# USER = ta user key (page d'accueil du compte). | https://pushover.net
PUSHOVER_TOKEN=
PUSHOVER_USER=

# ═══ Dark web — Module C (Tor / Ahmia) ══════════════════════════════════════
# Garde-fou : désactivé par défaut. Activer avec INDIC_DARKWEB_ENABLED=1.
INDIC_DARKWEB_ENABLED=
# Mots-clés pour la recherche Ahmia.fi (séparés par des virgules).
INDIC_DARKWEB_KEYWORDS=

# ═══ Sans clé (enrichers codés directement, rien à remplir) ═══════════════
# OSV.dev · CIRCL hashlookup · StopForumSpam · DShield/ISC · Wayback · Hudson Rock ·
# iCloud Private Relay · Spamhaus DROP · Feodo · IPsum · hagezi · Phishing Army ·
# red.flag.domains · NordVPN · Mullvad · RIPEstat · InternetDB · Shodan CVEDB · Gravatar
#
# Retirés (services morts en 2026) : SpyOnWeb (API défunte), InQuest Labs (déprécié post-OPSWAT).
